# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key — found in Supabase dashboard > Settings > API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=xxx

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Used by the backend (Pi) to call Claude via claude-agent-sdk
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── AI Relay ────────────────────────────────────────────────────────────────
# Shared secret between relay server and backend — use any random string
RELAY_SECRET=xxx

# [frontend / Vercel] WebSocket URL pointing to the relay server
# Dev:  ws://localhost:3001
# Prod: wss://your-relay-domain.com
NUXT_PUBLIC_WS_URL=ws://localhost:3001

# [backend / Pi] WebSocket URL the backend dials to reach the relay
# Dev:  ws://localhost:3001
# Prod: wss://your-relay-domain.com
RELAY_URL=ws://localhost:3001
